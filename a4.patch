diff --git a/testnull.c b/testnull.c
new file mode 100644
index 0000000..db3b288
--- /dev/null
+++ b/testnull.c
@@ -0,0 +1,17 @@
+#include "types.h"
+#include "stat.h"
+#include "user.h"
+
+int
+main(void)
+{
+  printf(1, "about to dereference NULL\n");
+  asm volatile(
+    "movl $0, %%eax\n\t"
+    "movl $1, (%%eax)\n\t"
+    :
+    :
+    : "%eax", "memory"
+  );
+  exit();
+}
diff --git a/testprotect.c b/testprotect.c
new file mode 100644
index 0000000..604d8c2
--- /dev/null
+++ b/testprotect.c
@@ -0,0 +1,37 @@
+#include "types.h"
+#include "stat.h"
+#include "user.h"
+
+int
+main(void)
+{
+  int *p;
+  int pid;
+
+  printf(1, "allocating one page\n");
+  p = (int*)sbrk(4096);
+
+  p[0] = 123;
+  printf(1, "initial write ok\n");
+
+  mprotect((void*)p, 1);
+  printf(1, "page protected\n");
+
+  pid = fork();
+  if(pid == 0){
+    printf(1, "child writing to protected page\n");
+    p[0] = 456;
+    printf(1, "child write unexpectedly succeeded\n");
+    exit();
+  }
+
+  wait();
+
+  munprotect((void*)p, 1);
+  printf(1, "page unprotected\n");
+
+  p[0] = 789;
+  printf(1, "write after munprotect ok: %d\n", p[0]);
+
+  exit();
+}
