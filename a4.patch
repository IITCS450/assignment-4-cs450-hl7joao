- { (void*)DEVSPACE, DEVSPACE,      0,         PTE_W}, // more devices
+ { (void*)KERNBASE, 0,             EXTMEM,    PTE_W},
+ { (void*)KERNLINK, V2P(KERNLINK), V2P(data), 0},
+ { (void*)data,     V2P(data),     PHYSTOP,   PTE_W},
+ { (void*)DEVSPACE, DEVSPACE,      0,         PTE_W},
