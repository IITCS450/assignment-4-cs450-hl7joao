+
+int
+sys_mprotect(void)
+{
+  int addr, len, i;
+  uint va;
+  pte_t *pte;
+  struct proc *p = myproc();
+
+  if(argint(0, &addr) < 0 || argint(1, &len) < 0)
+    return -1;
+
+  if(len <= 0)
+    return -1;
+  if(addr < PGSIZE)
+    return -1;
+  if(addr % PGSIZE != 0)
+    return -1;
+
+  for(i = 0; i < len; i++){
+    va = addr + i * PGSIZE;
+
+    if(va >= p->sz)
+      return -1;
+
+    pte = walkpgdir(p->pgdir, (void*)va, 0);
+    if(pte == 0 || !(*pte & PTE_P))
+      return -1;
+
+    *pte &= ~PTE_W;
+  }
+
+  lcr3(V2P(p->pgdir));
+  return 0;
+}
+
+int
+sys_munprotect(void)
+{
+  int addr, len, i;
+  uint va;
+  pte_t *pte;
+  struct proc *p = myproc();
+
+  if(argint(0, &addr) < 0 || argint(1, &len) < 0)
+    return -1;
+
+  if(len <= 0)
+    return -1;
+  if(addr < PGSIZE)
+    return -1;
+  if(addr % PGSIZE != 0)
+    return -1;
+
+  for(i = 0; i < len; i++){
+    va = addr + i * PGSIZE;
+
+    if(va >= p->sz)
+      return -1;
+
+    pte = walkpgdir(p->pgdir, (void*)va, 0);
+    if(pte == 0 || !(*pte & PTE_P))
+      return -1;
+
+    *pte |= PTE_W;
+  }
+
+  lcr3(V2P(p->pgdir));
+  return 0;
+}
